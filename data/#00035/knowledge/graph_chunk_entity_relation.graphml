    <edge source="Historical Fact-Enhanced Reward Module (HFRM)" target="Factuality-Oriented Reward Mechanism For Historical Entities">
      <data key="weight">1.0</data>
      <data key="description">The Factuality-Oriented Reward Mechanism For Historical Entities includes the Historical Fact-Enhanced Reward Module (HFRM) to capture alignment with facts.</data>
