    <node id="YOLO Detectors">
      <data key="entity_id">YOLO Detectors</data>
      <data key="entity_type">method</data>
      <data key="description">A family of CNN-based one-stage object detectors widely used for real-time detection, requiring NMS post-processing.</data>
      <data key="source_id">chunk-cf30e7371cd8c7ca86d01ccde3c99b27</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773737745</data>
